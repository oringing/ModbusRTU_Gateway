# 嵌入式 C 代码格式化规则 - 行业主流风格
# 基于：Linux 内核风格 + MISRA 约束 + 嵌入式团队惯例
# 适用：STM32F103 + FreeRTOS + Modbus RTU 网关项目

Language: C

# ==================== 基础缩进 ====================
IndentWidth: 4
TabWidth: 4
UseTab: Never                    # 4空格缩进（80%嵌入式团队采用）
BreakBeforeBraces: Attach        # K&R风格：左括号不换行（行业主流）

# ==================== 列宽限制 ====================
ColumnLimit: 100                 # 现代团队标准（80-120字符）

# ==================== 指针对齐 ====================
PointerAlignment: Left           # * 靠近变量名：int *ptr
ReferenceAlignment: Left

# ==================== 空格控制 ====================
SpaceAfterCStyleCast: false      # (int)x 不加空格
SpaceBeforeParens: ControlStatements  # if/for/while 后加空格
SpacesBeforeTrailingComments: 1  # 行尾注释前1个空格
SpacesInParentheses: false       # (expr) 内部不加空格
SpacesInSquareBrackets: false    # array[0] 内部不加空格

# ==================== 换行控制 ====================
# MISRA 要求：函数体必须可见，禁止压缩
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AlwaysBreakBeforeMultilineStrings: false

# ==================== 宏和预处理 ====================
IndentPPDirectives: AfterHash    # #define 缩进

# ==================== 注释对齐 ====================
AlignTrailingComments: true      # 行尾注释对齐
ReflowComments: true             # 自动重排注释换行

# ==================== 声明对齐（MISRA 友好）====================
AlignConsecutiveAssignments: false   # 关闭连续赋值对齐（避免过度对齐）
AlignConsecutiveDeclarations: true   # 连续声明对齐（保留）

# ==================== 头文件排序 ====================
SortIncludes: CaseInsensitive
IncludeBlocks: Preserve          # 保留原有分组

# ==================== 其他 ====================
BreakBeforeBinaryOperators: None
BreakBeforeTernaryOperators: true
Cpp11BracedListStyle: true
DerivePointerAlignment: false
SortUsingDeclarations: true
